{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A woodworking project",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "brand": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string" },
        "assigned_to": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "completedAt": { "type": "string" }
      },
      "required": ["brand", "title", "status", "assigned_to", "createdAt", "updatedAt"]
    },
    "PurchaseOrder": {
      "title": "PurchaseOrder",
      "description": "A purchase order for supplies",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "brand": { "type": "string" },
        "vendor": { "type": "string" },
        "date": { "type": "string" },
        "total_amount": { "type": "number" },
        "status": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["brand", "vendor", "date", "total_amount", "status", "createdAt"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": { "$ref": "Project" },
      "description": "Projects collection"
    },
    "/purchase_orders/{poId}": {
      "schema": { "$ref": "PurchaseOrder" },
      "description": "Purchase orders collection"
    }
  }
}
