{
  "entities": {
    "inventory_item": {
      "title": "Inventory Item",
      "description": "Raw materials, furniture pieces, or supplies used in the shop.",
      "type": "object",
      "properties": {
        "owner": {
          "type": "string",
          "enum": ["Twisted Twig", "Wood Grain Alchemist"],
          "description": "Which business entity owns this item."
        },
        "type": {
          "type": "string",
          "enum": ["Raw Material", "Furniture Piece", "Supply"],
          "description": "Category of the item."
        },
        "name": {
          "type": "string",
          "description": "Name of the item (e.g., Black Oak, Victorian Dresser)."
        },
        "quantity": {
          "type": "number",
          "description": "Amount in board feet or units."
        },
        "acquisition_cost": {
          "type": "number",
          "description": "Cost to acquire the item."
        },
        "current_condition": {
          "type": "integer",
          "description": "Scale 1-10 (primarily for Twisted Twig pieces)."
        },
        "location": {
          "type": "string",
          "description": "Where the item is stored (e.g., Shop floor, Storage)."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["owner", "type", "name", "quantity", "acquisition_cost"]
    },
    "project": {
      "title": "Project",
      "description": "A refurbishing or custom build project.",
      "type": "object",
      "properties": {
        "brand": {
          "type": "string",
          "enum": ["Twisted Twig", "Wood Grain Alchemist"],
          "description": "Which brand is leading the project."
        },
        "client_id": {
          "type": "string",
          "description": "ID of the customer."
        },
        "status": {
          "type": "string",
          "enum": ["Intake", "Assessment", "Structural Repair", "Finishing", "Complete"],
          "description": "Current phase of the project."
        },
        "assigned_to": {
          "type": "string",
          "description": "Who is working on it (e.g., Andrew, Jordan)."
        },
        "financials": {
          "type": "object",
          "properties": {
            "item_cost": { "type": "number" },
            "supplies_cost": { "type": "number" },
            "labor_hours": { "type": "number" },
            "hourly_rate": { "type": "number" },
            "pricing_strategy": { "type": "string" },
            "target_sale_price": { "type": "number" },
            "actual_sale_price": { "type": "number" }
          }
        },
        "work_log": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "timestamp": { "type": "string", "format": "date-time" },
              "action": { "type": "string" },
              "notes": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["brand", "status"]
    },
    "customer": {
      "title": "Customer",
      "description": "Customer contact and history.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "contact": { "type": "string", "description": "Email or phone." },
        "purchase_history": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of project IDs."
        }
      },
      "required": ["name", "contact"]
    }
  },
  "firestore": {
    "inventory": {
      "schema": "inventory_item",
      "description": "Shop inventory items."
    },
    "projects": {
      "schema": "project",
      "description": "Active and completed projects."
    },
    "customers": {
      "schema": "customer",
      "description": "Customer database."
    }
  }
}
