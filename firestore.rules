rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: projects
    // Document ID: {projectId}
    // Fields:
    //   - brand: string (required)
    //   - title: string (required)
    //   - description: string (required)
    //   - status: string (required)
    //   - assigned_to: string (required)
    //   - createdAt: string (required, immutable)
    //   - updatedAt: string (required)
    //   - completedAt: string (optional)
    //
    // Collection: purchase_orders
    // Document ID: {poId}
    // Fields:
    //   - brand: string (required)
    //   - vendor: string (required)
    //   - date: string (required)
    //   - total_amount: number (required)
    //   - status: string (required)
    //   - createdAt: string (required, immutable)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /projects/{projectId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && hasRequiredFields(['brand', 'title', 'description', 'status', 'assigned_to', 'createdAt', 'updatedAt']);
      allow update: if isAuthenticated() && areImmutableFieldsUnchanged(['createdAt']);
      allow delete: if isAuthenticated();
    }

    match /purchase_orders/{poId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && hasRequiredFields(['brand', 'vendor', 'date', 'total_amount', 'status', 'createdAt']);
      allow update: if isAuthenticated() && areImmutableFieldsUnchanged(['createdAt']);
      allow delete: if isAuthenticated();
    }

    match /shop_notes/{noteId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /inventory/{itemId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /customers/{customerId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
  }
}
